{
  "name": "arey-pi",
  "version": "0.2.0",
  "description": "A Pi package for canonical Gherkin specs, non-negotiable TDD, spec synchronisation, AI harness readiness, and senior-quality software delivery.",
  "license": "MIT",
  "author": "Alejandro Rey Leyva",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/alereyleyva/arey-pi.git"
  },
  "bugs": {
    "url": "https://github.com/alereyleyva/arey-pi/issues"
  },
  "homepage": "https://github.com/alereyleyva/arey-pi#readme",
  "keywords": [
    "pi-package",
    "pi",
    "spec-driven-development",
    "gherkin",
    "tdd",
    "software-engineering"
  ],
  "files": [
    "agents/",
    "extensions/",
    "skills/",
    "prompts/",
    "rules/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/arey-pi.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "check": "node -e \"JSON.parse(require('fs').readFileSync('package.json', 'utf8'))\" && tsc --noEmit",
    "prepublishOnly": "npm run check && npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  }
}
